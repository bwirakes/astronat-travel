{
  "name": "astronat",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && bun run dev",
    "dev:mobile": "cd apps/mobile && bun run start",
    "ios": "cd apps/mobile && bun run ios",
    "android": "cd apps/mobile && bun run android",
    "mobile:web": "cd apps/mobile && bun run web",
    "build": "cd apps/web && bun run build",
    "start": "cd apps/web && bun run start",
    "lint": "cd apps/web && bun run lint",
    "test": "cd apps/web && bun run test",
    "test:ui": "cd apps/web && bun run test:ui",
    "test:unit": "cd apps/web && bun run test:unit",
    "lint:mobile": "cd apps/mobile && bun run lint"
  },
  "packageManager": "bun@1.3.10"
}
